# RPC endpoint (devnet, localnet, or mainnet-beta)
RPC_URL=https://api.devnet.solana.com

# Path to the keeper keypair (the wallet that signs cron tx's)
# Must match protocol_state.keeper_authority after `set_keeper`
KEYPAIR_PATH=./keeper-keypair.json

# Path to the admin keypair (only needed in stub-oracle mode for devnet,
# because set_rate_index_oracle requires the admin authority)
ADMIN_KEYPAIR_PATH=./admin-keypair.json

# Anemone program ID
PROGRAM_ID=KQs6ci5FtedFKPVJThAZSMMXyosK4TvnF7kcDSx5Jwd

# Kamino USDC Reserve (only used when USE_STUB_ORACLE=false)
KAMINO_RESERVE=D6q6wuQSrifJKZYpR1M8R4YawnLDtDsMmWM1NbBmgJ59

# The market we're keeping alive. Derived from [b"market", reserve, tenor_le].
# For devnet we typically use a fresh Keypair as the "reserve" placeholder.
MARKET_PDA=

# "true" for devnet (use set_rate_index_oracle), "false" for mainnet (use update_rate_index)
USE_STUB_ORACLE=true

# How much to bump the rate_index per stub call (scales to ~10% APY when called every 3 min)
STUB_RATE_INCREMENT=1000000000000

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
